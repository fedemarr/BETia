# Claude AI (obligatorio)
ANTHROPIC_API_KEY=sk-ant-...
# Opciones: claude-sonnet-4-6 (recomendado ~$0.04/análisis), claude-opus-4-8 (más potente), claude-haiku-4-5 (más económico ~$0.014/análisis)
CLAUDE_MODEL=claude-sonnet-4-6

# Supabase / PostgreSQL (obligatorio)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# The Odds API — cuotas en tiempo real (50 req/mes gratis)
# Registrate en: https://the-odds-api.com
ODDS_API_KEY=

# BallDontLie — NBA stats (gratis, key opcional para más requests)
# https://www.balldontlie.io
BALLDONTLIE_API_KEY=

# api-tennis.com — datos históricos de tenis
API_TENNIS_KEY=

# Sportradar — premium, cubre todos los deportes
SPORTRADAR_API_KEY=
